# Logs
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
tsconfig.tsbuildinfo

# Next.js
.next/
out/
next-env.d.ts

# Monaco editor local files (copied from node_modules)
public/vs

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Test artifacts
coverage/
*.snap.new
.vitest-cache/

# macOS signing material. Keep certificates and exported private keys out of git.
*.cer
*.csr
*.p12
certificate-base64.txt

# Agent
.claude
.docs
docs/superpowers

# Tauri sidecar staging (built per-target by prepare-sidecars.mjs).
# The binaries are platform-specific build artifacts; ship them through
# release.yml, not git.
src-tauri/binaries/

# Compiled binaries / build artifacts (Rust target dir, stray exes).
# These are produced by `pnpm tauri build`; never commit them.
src-tauri/target/
*.exe
!src-tauri/binaries/.gitkeep

# pnpm local store (pnpm 11+)
.pnpm-store/

# sccache local cache (do not commit; migrate manually per BUILD-SPEED.md)
.sccache/
